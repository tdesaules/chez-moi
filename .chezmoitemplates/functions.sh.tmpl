NC='\033[0m'
BOLD='\033[1m'
WHITE='\033[1;37m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
MAGENTA='\033[0;35m'
PINK='\033[38;5;205m'

_log() {
    local LEVEL=$1
    local MSG=$2
    local TIME=$(date +"%H:%M:%S")
    local COLOR=$NC
    local ICON="  "

    case " ${LEVEL} " in
        " title ")    COLOR=$PINK;      ICON="    󰄾 " ;;
        " debug ")    COLOR=$WHITE;     ICON="     " ;;
        " info ")     COLOR=$BLUE;      ICON="      " ;;
        " notice ")   COLOR=$CYAN;      ICON="    " ;;
        " success ")  COLOR=$GREEN;     ICON="   " ;;
        " warning ")  COLOR=$YELLOW;    ICON="   " ;;
        " error ")    COLOR=$RED;       ICON="     " ;;
        " critical ") COLOR=$MAGENTA;   ICON="  " ;;
    esac

    # I kept your formatting but used BOLD for the title to make it pop
    echo -e "${WHITE}[ $TIME ]${NC} ${COLOR}${BOLD}[ ${LEVEL^^} ]${NC} ${COLOR}$ICON $MSG${NC} \n"
}

_error_handler() {
    local TASK="${1:-unknown task}"
    _log "critical" "failed during task: ${TASK}"
    exit 1
}
