[user]
    name = {{ .git.user.name | quote }}
    email = {{ .git.user.email | quote }}
    signingkey = {{ .chezmoi.homeDir }}/.ssh/id_ed25519.pub

[core]
    pager = delta
    editor = nvim
    autocrlf = input
    filemode = false

[interactive]
    diffFilter = delta --color-only

[sequence]
    editor = interactive-rebase-tool

[delta]
    features = nord-theme
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Nord

[merge]
    conflictstyle = zdiff3
    tool = nvimdiff

[mergetool "nvimdiff"]
    layout = "LOCAL,BASE,REMOTE / MERGED"

[diff]
    colorMoved = default
    algorithm = histogram

[alias]
    st = status
    co = checkout
    br = branch
    ri = "!f() { git rebase -i HEAD~$1; }; f"
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[push]
    autoSetupRemote = true

[init]
    defaultBranch = main

[fetch]
    prune = true

[pull]
    rebase = true

[rebase]
    autoStash = true

[gpg]
    format = ssh

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[credential]
    helper = cache --timeout=86400
    helper = gopass
