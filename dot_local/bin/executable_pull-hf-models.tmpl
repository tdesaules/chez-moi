#!/bin/bash
set -euo pipefail

for cmd in hf kcl jq; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "ERROR: Command '$cmd' not found." >&2
        exit 1
    fi
done

export HF_TOKEN="{{ gopass "perso/token/huggingface.co/9161b82f-5aad-45e0-be35-2332d675fc59" | trim }}"

CONFIG_FILE="{{ .chezmoi.homeDir }}/.config/models/config.kcl"
CONFIG_JSON=$(kcl "$CONFIG_FILE" --format json 2>/dev/null)

if [ -z "$CONFIG_JSON" ]; then
    echo "ERROR: Unable to read config from $CONFIG_FILE" >&2
    exit 1
fi

DOWNLOAD_DIR=$(echo "$CONFIG_JSON" | jq -r ".download_dir")

if [ -z "$DOWNLOAD_DIR" ]; then
    echo "ERROR: download_dir is empty in $CONFIG_FILE" >&2
    exit 1
fi

CACHE_DIR="$DOWNLOAD_DIR/.hf-cache"
mkdir -p "$CACHE_DIR"

TOTAL=$(echo "$CONFIG_JSON" | jq '.models | length')
CURRENT=0
SUCCESS=0
FAIL=0
SKIP=0
MAX_RETRIES=3
RETRY_DELAY=5

while read -r model_json; do
    CURRENT=$((CURRENT + 1))
    REPO=$(echo "$model_json" | jq -r '.repo')
    FILE=$(echo "$model_json" | jq -r '.file')

    echo "[$CURRENT/$TOTAL] $FILE from $REPO"

    if [ -L "$DOWNLOAD_DIR/$FILE" ] && [ ! -e "$DOWNLOAD_DIR/$FILE" ]; then
        rm -f "$DOWNLOAD_DIR/$FILE"
    fi

    if [ -e "$DOWNLOAD_DIR/$FILE" ]; then
        echo "  Already exists, skipping."
        SKIP=$((SKIP + 1))
        continue
    fi

    rm -f "$DOWNLOAD_DIR/.cache/huggingface/download/$FILE.lock"

    ATTEMPT=0
    DOWNLOADED=false
    while [ "$ATTEMPT" -lt "$MAX_RETRIES" ]; do
        ATTEMPT=$((ATTEMPT + 1))
        if [ "$ATTEMPT" -gt 1 ]; then
            echo "  Retry $ATTEMPT/$MAX_RETRIES for $FILE..."
            sleep "$RETRY_DELAY"
        fi
        if hf download "$REPO" "$FILE" --cache-dir "$CACHE_DIR" 2>&1; then
            DOWNLOADED=true
            break
        fi
        echo "  Attempt $ATTEMPT failed for $FILE" >&2
    done

    if [ "$DOWNLOADED" = true ]; then
        REPO_CACHE_NAME="models--$(echo "$REPO" | sed 's/\//--/g')"
        SNAPSHOT_HASH=$(ls "$CACHE_DIR/$REPO_CACHE_NAME/snapshots/" 2>/dev/null | head -1)
        if [ -n "$SNAPSHOT_HASH" ] && [ -e "$CACHE_DIR/$REPO_CACHE_NAME/snapshots/$SNAPSHOT_HASH/$FILE" ]; then
            ln -sf ".hf-cache/$REPO_CACHE_NAME/snapshots/$SNAPSHOT_HASH/$FILE" "$DOWNLOAD_DIR/$FILE"
            echo "  Downloaded and symlinked."
            SUCCESS=$((SUCCESS + 1))
        else
            echo "ERROR: Download succeeded but snapshot not found for $FILE" >&2
            FAIL=$((FAIL + 1))
        fi
    else
        echo "ERROR: Failed to download $FILE after $MAX_RETRIES attempts" >&2
        FAIL=$((FAIL + 1))
    fi
done < <(echo "$CONFIG_JSON" | jq -c '.models[]')

echo ""
echo "Cleaning up orphaned models in $DOWNLOAD_DIR..."

EXPECTED_FILES=$(echo "$CONFIG_JSON" | jq -r '.models[].file' | sort -u)
EXPECTED_REPOS=$(echo "$CONFIG_JSON" | jq -r '.models[].repo' | sort -u)

ORPHAN_FLAT=0
while read -r filepath; do
    [ -z "$filepath" ] && continue
    f=$(basename "$filepath")
    if ! grep -qxF "$f" <<< "$EXPECTED_FILES"; then
        echo "  Removing orphan file: $f"
        rm -f "$filepath"
        ORPHAN_FLAT=$((ORPHAN_FLAT + 1))
    fi
done < <(find "$DOWNLOAD_DIR" -maxdepth 1 \( -type f -o -type l \))

BROKEN=0
while read -r brokenlink; do
    [ -z "$brokenlink" ] && continue
    echo "  Removing broken symlink: $(basename "$brokenlink")"
    rm -f "$brokenlink"
    BROKEN=$((BROKEN + 1))
done < <(find "$DOWNLOAD_DIR" -maxdepth 1 -type l ! -exec test -e {} \; -print)

OLD_CACHE_DIR="$DOWNLOAD_DIR/.cache"
if [ -d "$OLD_CACHE_DIR" ]; then
    echo "  Removing old --local-dir cache..."
    rm -rf "$OLD_CACHE_DIR"
fi

ORPHAN_CACHE=0
CACHED_REPOS=$(hf cache list --cache-dir "$CACHE_DIR" --format quiet 2>/dev/null || true)
for cached_repo in $CACHED_REPOS; do
    repo_id="${cached_repo#model/}"
    if ! grep -qxF "$repo_id" <<< "$EXPECTED_REPOS"; then
        echo "  Removing orphan cache repo: $repo_id"
        hf cache rm "$cached_repo" --cache-dir "$CACHE_DIR" -y 2>/dev/null || true
        ORPHAN_CACHE=$((ORPHAN_CACHE + 1))
    fi
done

hf cache prune --cache-dir "$CACHE_DIR" -y 2>/dev/null || true

echo ""
echo "Cleanup complete: $ORPHAN_FLAT orphan file(s), $BROKEN broken symlink(s), $ORPHAN_CACHE orphan cache repo(s)."
echo "Summary: $SUCCESS downloaded, $SKIP skipped, $FAIL failed."

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi

exit 0