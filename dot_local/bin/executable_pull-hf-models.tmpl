#!/bin/bash
set -euo pipefail

for cmd in hf kcl jq; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "ERROR: Command '$cmd' not found." >&2
        exit 1
    fi
done

export HF_TOKEN="{{ gopass "perso/token/huggingface.co/9161b82f-5aad-45e0-be35-2332d675fc59" | trim }}"

CONFIG_FILE="{{ .chezmoi.homeDir }}/.config/models/config.kcl"
CONFIG_JSON=$(kcl "$CONFIG_FILE" --format json 2>/dev/null)

if [ -z "$CONFIG_JSON" ]; then
    echo "ERROR: Unable to read config from $CONFIG_FILE" >&2
    exit 1
fi

DOWNLOAD_DIR=$(echo "$CONFIG_JSON" | jq -r ".download_dir")

if [ -z "$DOWNLOAD_DIR" ]; then
    echo "ERROR: download_dir is empty in $CONFIG_FILE" >&2
    exit 1
fi

TOTAL=$(echo "$CONFIG_JSON" | jq '.models | length')
CURRENT=0
SUCCESS=0
FAIL=0

while read -r model_json; do
    CURRENT=$((CURRENT + 1))
    REPO=$(echo "$model_json" | jq -r '.repo')
    FILE=$(echo "$model_json" | jq -r '.file')

    echo "[$CURRENT/$TOTAL] Downloading $FILE from $REPO..."

    rm -f "$DOWNLOAD_DIR/.cache/huggingface/download/$FILE.lock"

    if hf download "$REPO" "$FILE" --local-dir "$DOWNLOAD_DIR" 2>&1; then
        SUCCESS=$((SUCCESS + 1))
    else
        echo "ERROR: Failed to download $FILE from $REPO" >&2
        FAIL=$((FAIL + 1))
    fi
done < <(echo "$CONFIG_JSON" | jq -c '.models[]')

# --- Cleanup: remove models no longer in the config ---
echo "Cleaning up orphaned models in $DOWNLOAD_DIR..."

EXPECTED_FILES=$(echo "$CONFIG_JSON" | jq -r '.models[].file' | sort -u)

ORPHAN_MAIN=0
while read -r filepath; do
    [ -z "$filepath" ] && continue
    f=$(basename "$filepath")
    if ! grep -qxF "$f" <<< "$EXPECTED_FILES"; then
        echo "  Removing orphan model: $f"
        rm -f "$filepath"
        ORPHAN_MAIN=$((ORPHAN_MAIN + 1))
    fi
done < <(find "$DOWNLOAD_DIR" -maxdepth 1 -type f)

AUX_DIR="$DOWNLOAD_DIR/.cache/huggingface/download"
ORPHAN_AUX=0
if [ -d "$AUX_DIR" ]; then
    while read -r auxpath; do
        [ -z "$auxpath" ] && continue
        auxname=$(basename "$auxpath")
        base="${auxname%.metadata}"
        base="${base%.lock}"
        if ! grep -qxF "$base" <<< "$EXPECTED_FILES"; then
            echo "  Removing orphan auxiliary: $auxname"
            rm -f "$auxpath"
            ORPHAN_AUX=$((ORPHAN_AUX + 1))
        fi
    done < <(find "$AUX_DIR" -maxdepth 1 -type f \( -name '*.metadata' -o -name '*.lock' \))
fi

if [ "$ORPHAN_MAIN" -gt 0 ] || [ "$ORPHAN_AUX" -gt 0 ]; then
    echo "Cleanup complete: $ORPHAN_MAIN model file(s), $ORPHAN_AUX auxiliary file(s) removed."
else
    echo "No orphaned models found."
fi

if [ "$FAIL" -gt 0 ]; then
    echo "Completed with $FAIL failures, $SUCCESS succeeded" >&2
    exit 1
fi

echo "All models updated successfully ($SUCCESS downloaded)"
exit 0
