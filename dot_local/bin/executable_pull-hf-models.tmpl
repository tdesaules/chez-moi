#!/bin/bash

for cmd in hf kcl jq; do
    if ! command -v $cmd &> /dev/null; then
        echo "ERROR: Command '$cmd' not found." >&2
        exit 1
    fi
done

CONFIG_FILE="{{ .chezmoi.homeDir }}/.config/models/config.kcl"
DOWNLOAD_DIR=$(kcl "$CONFIG_FILE" --format json 2>/dev/null | jq -r ".download_dir")

if [ -z "$DOWNLOAD_DIR" ]; then
    echo "ERROR: Unable to read download_dir" >&2
    exit 1
fi

TOTAL=$(kcl "$CONFIG_FILE" --format json 2>/dev/null | jq '.models | length')
CURRENT=0
SUCCESS=0
FAIL=0

kcl "$CONFIG_FILE" --format json 2>/dev/null | jq -c '.models[]' | while read -r model_json; do
    CURRENT=$((CURRENT + 1))
    REPO=$(echo "$model_json" | jq -r '.repo')
    FILE=$(echo "$model_json" | jq -r '.file')

    echo "[$CURRENT/$TOTAL] Downloading $FILE from $REPO..."

    if hf download "$REPO" "$FILE" --local-dir "$DOWNLOAD_DIR" 2>&1; then
        SUCCESS=$((SUCCESS + 1))
    else
        echo "ERROR: Failed to download $FILE from $REPO" >&2
        FAIL=$((FAIL + 1))
    fi
done
if [ $FAIL -gt 0 ]; then
    echo "Completed with $FAIL failures" >&2
    exit 1
fi

echo "All models updated successfully"
exit 0
