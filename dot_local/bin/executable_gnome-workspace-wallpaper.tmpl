#!/usr/bin/env python3
import subprocess
import sys

from gi.repository import Gio, GLib

# --- CONFIGURATION ---
# Map your workspace indices to your Nord wallpapers
WALLPAPERS = {
    0: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/0.png",
    1: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/1.png",
}


def set_wallpaper(uri: str):
    """Sets the wallpaper for both light and dark modes."""
    try:
        # Use gsettings to apply the wallpaper
        subprocess.run(
            ["gsettings", "set", "org.gnome.desktop.background", "picture-uri", uri],
            check=True,
        )
        subprocess.run(
            [
                "gsettings",
                "set",
                "org.gnome.desktop.background",
                "picture-uri-dark",
                uri,
            ],
            check=True,
        )
    except subprocess.SubprocessError:
        # Log error to stderr without crashing the daemon
        print(f"Error: Could not set wallpaper to {uri}", file=sys.stderr)


def get_active_workspace() -> int:
    """Queries the current active workspace index via D-Bus."""
    cmd = [
        "gdbus",
        "call",
        "--session",
        "--dest",
        "org.gnome.Shell",
        "/org/gnome/Shell",
        "org.gnome.Shell",
        "Eval",
        "global.workspace_manager.get_active_workspace_index()",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        # GNOME Eval returns: (true, '0')
        return int(result.stdout.split("'")[1])
    except (IndexError, ValueError, subprocess.SubprocessError):
        return 0


def workspace_monitor():
    """Listens for workspace changes and updates the wallpaper."""
    # We monitor the 'number-of-workspaces' key as a trigger bridge
    # because GNOME Shell signals are harder to hook without a direct extension.
    settings = Gio.Settings.new("org.gnome.desktop.wm.preferences")

    def update_background(*args):
        idx = get_active_workspace()
        wallpaper = WALLPAPERS.get(idx, WALLPAPERS[0])
        set_wallpaper(wallpaper)

    # Connect to the signal when workspace configuration changes
    settings.connect("changed::num-workspaces", update_background)

    # Also, we can set a timer to check periodically or rely on Shell signals.
    # For now, this event-based approach is the most battery-efficient.

    # Set the initial wallpaper on start
    update_background()

    loop = GLib.MainLoop()
    try:
        loop.run()
    except KeyboardInterrupt:
        loop.quit()


if __name__ == "__main__":
    workspace_monitor()
