#!/usr/bin/env python3
import subprocess
import sys

from gi.repository import GLib

# --- CONFIGURATION ---
# Map your workspace indices to your wallpapers
WALLPAPERS = {
    0: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/0.png",
    1: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/1.png",
    2: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/2.png",
    3: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/3.png",
    4: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/4.png",
    5: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/5.png",
    6: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/6.png",
    7: "file://{{ .chezmoi.homeDir }}/.local/share/backgrounds/7.png",
}


class WorkspaceDaemon:
    def __init__(self):
        self.last_index = -1

    def set_wallpaper(self, uri: str):
        """Sets the wallpaper for both light and dark modes."""
        try:
            subprocess.run(
                [
                    "gsettings",
                    "set",
                    "org.gnome.desktop.background",
                    "picture-uri",
                    uri,
                ],
                check=True,
            )
            subprocess.run(
                [
                    "gsettings",
                    "set",
                    "org.gnome.desktop.background",
                    "picture-uri-dark",
                    uri,
                ],
                check=True,
            )
        except subprocess.SubprocessError:
            print(f"Error: Could not set wallpaper to {uri}", file=sys.stderr)

    def get_active_workspace(self) -> int:
        """Queries the current active workspace index via D-Bus."""
        cmd = [
            "gdbus",
            "call",
            "--session",
            "--dest",
            "org.gnome.Shell",
            "/org/gnome/Shell",
            "org.gnome.Shell",
            "Eval",
            "global.workspace_manager.get_active_workspace_index()",
        ]
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, check=True)
            return int(result.stdout.split("'")[1])
        except (IndexError, ValueError, subprocess.SubprocessError):
            return 0

    def check_workspace(self):
        """Check if workspace changed and update wallpaper if needed."""
        current_index = self.get_active_workspace()
        if current_index != self.last_index:
            self.last_index = current_index
            wallpaper = WALLPAPERS.get(current_index, WALLPAPERS[0])
            self.set_wallpaper(wallpaper)
        return True  # Keep the timer running


def main():
    daemon = WorkspaceDaemon()
    # Check every 500ms for a workspace switch
    GLib.timeout_add(500, daemon.check_workspace)

    loop = GLib.MainLoop()
    try:
        loop.run()
    except KeyboardInterrupt:
        loop.quit()


if __name__ == "__main__":
    main()
