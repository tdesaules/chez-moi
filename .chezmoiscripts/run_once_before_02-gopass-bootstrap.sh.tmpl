#!/bin/bash

{{- if and .is_mise .is_ssh }}

{{ include ".chezmoitemplates/functions.tmpl" }}

_log "info" "installing gopass and gh via mise..."
if ! output=$(mise use -g github:gopasspw/gopass@latest github:cli/cli@latest 2>&1); then
    echo "$output"
    _error_handler "mise tools installation"
fi

_log "success" "gopass and gh installed"

if ! "{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh" auth status >/dev/null 2>&1; then
    _log "info" "github authentication required"
    _log "notice" "scan the QR code with your phone or open https://github.com/login/device"
    curl -s "qrenco.de/https://github.com/login/device" 2>/dev/null || true
    if ! "{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh" auth login -h github.com -p ssh --skip-ssh-key -s admin:public_key --web; then
        _error_handler "github authentication"
    fi
    _log "success" "authenticated to github"
else
    _log "info" "already authenticated to github"
fi

SSH_FINGERPRINT=$(ssh-keygen -lf "{{ .chezmoi.homeDir }}/{{ .ssh.dir }}/{{ .ssh.key.name }}.pub" 2>/dev/null | awk '{print $2}')
if "{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh" ssh-key list 2>/dev/null | grep -q "$SSH_FINGERPRINT"; then
    _log "info" "ssh key already on github"
else
    _log "info" "uploading ssh key to github..."
    if ! OUTPUT=$("{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh" ssh-key add "{{ .chezmoi.homeDir }}/{{ .ssh.dir }}/{{ .ssh.key.name }}.pub" --title "chezmoi-{{ .chezmoi.hostname }}" 2>&1); then
        echo "$OUTPUT"
        _error_handler "ssh key upload to github"
    fi
    _log "success" "ssh key uploaded"
fi

_log "info" "adding github.com to known_hosts..."
mkdir -p "{{ .chezmoi.homeDir }}/{{ .ssh.dir }}"
ssh-keyscan github.com >> "{{ .chezmoi.homeDir }}/{{ .ssh.dir }}/known_hosts" 2>/dev/null

if [ ! -e "{{ .gopass.age.device }}" ]; then
    _log "warning" "please insert the AGE USB key..."
    while [ ! -e "{{ .gopass.age.device }}" ]; do
        sleep 2
    done
fi
_log "info" "mounting AGE USB key..."
if ! output=$(/usr/bin/udisksctl mount -b "{{ .gopass.age.device }}" --no-user-interaction 2>&1); then
    echo "$output"
    _log "warning" "udisksctl mount failed (may already be mounted)"
fi

for i in $(seq 1 10); do
    [ -f "/run/media/{{ .chezmoi.username }}/{{ .gopass.age.label }}/identities" ] && break
    sleep 0.5
done

if [ ! -f "/run/media/{{ .chezmoi.username }}/{{ .gopass.age.label }}/identities" ]; then
    _error_handler "AGE USB identity retrieval"
fi

mkdir -p "{{ .chezmoi.homeDir }}/.config/gopass/age"
ln -sf "/run/media/{{ .chezmoi.username }}/{{ .gopass.age.label }}/identities" "{{ .chezmoi.homeDir }}/{{ .gopass.age.identity }}"
_log "success" "identity symlink created"

_log "info" "age identity is passphrase-protected, passphrase required"
read -s -r GOPASS_AGE_PASSWORD < /dev/tty
echo
export GOPASS_AGE_PASSWORD

if [ ! -d "{{ .chezmoi.homeDir }}/{{ .gopass.store.path }}/.git" ]; then
    _log "info" "cloning gopass store..."
    if ! OUTPUT=$("{{ .chezmoi.homeDir }}/.local/share/mise/shims/gopass" clone --crypto age "{{ .gopass.store.url }}" 2>&1); then
        echo "$OUTPUT"
        _error_handler "gopass store clone"
    fi
    _log "success" "gopass store cloned"
else
    _log "info" "gopass store already exists, skipping clone"
fi

_log "info" "unlocking gopass age agent..."
"{{ .chezmoi.homeDir }}/.local/share/mise/shims/gopass" age agent start > /dev/null 2>&1 || true
if ! OUTPUT=$("{{ .chezmoi.homeDir }}/.local/share/mise/shims/gopass" age agent unlock 2>&1); then
    echo "$OUTPUT"
    _error_handler "gopass age agent unlock"
fi
_log "success" "age agent unlocked"

unset GOPASS_AGE_PASSWORD

_log "success" "gopass bootstrap complete"

{{- end }}
