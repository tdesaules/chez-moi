#!/bin/bash
#
{{- if .is_fedora }}
{{ include ".chezmoitemplates/functions.tmpl" }}

# {{ include "dot_local/share/qemu/br-qemu.nmconnection" | sha256sum }}
# {{ include "dot_local/share/qemu/bridge.conf" | sha256sum }}

NM_CONN_SRC="{{ .chezmoi.homeDir }}/{{ .qemu.nm_src }}"
NM_CONN_DEST="{{ .qemu.nm_dest }}"
QEMU_BRIDGE_SRC="{{ .chezmoi.homeDir }}/{{ .qemu.bridge_src }}"
QEMU_BRIDGE_DEST="{{ .qemu.bridge_dest }}"

if [ -f "$NM_CONN_DEST" ] && diff -q "$NM_CONN_SRC" "$NM_CONN_DEST" >/dev/null 2>&1; then
    _log "info" "br-qemu.nmconnection already up to date, skipping"
else
    _log "info" "deploying br-qemu.nmconnection to $NM_CONN_DEST..."
    if ! output=$(sudo cp "$NM_CONN_SRC" "$NM_CONN_DEST" 2>&1); then
        echo "$output"
        _error_handler "br-qemu.nmconnection deployment"
    fi
    sudo chmod 600 "$NM_CONN_DEST"
    sudo nmcli connection reload 2>/dev/null || true
    # Restart the connection if currently active to apply new settings
    if nmcli -t -f NAME connection show --active 2>/dev/null | grep -q "^{{ .qemu.connection }}$"; then
        _log "info" "restarting {{ .qemu.connection }} connection to apply changes..."
        sudo nmcli connection down "{{ .qemu.connection }}" 2>/dev/null || true
        sudo nmcli connection up "{{ .qemu.connection }}" 2>/dev/null || true
        _log "success" "{{ .qemu.connection }} connection restarted"
    fi
    _log "success" "deployed br-qemu.nmconnection"
fi

if [ -f "$QEMU_BRIDGE_DEST" ] && diff -q "$QEMU_BRIDGE_SRC" "$QEMU_BRIDGE_DEST" >/dev/null 2>&1; then
    _log "info" "bridge.conf already up to date, skipping"
else
    _log "info" "deploying bridge.conf to $QEMU_BRIDGE_DEST..."
    if ! output=$(sudo cp "$QEMU_BRIDGE_SRC" "$QEMU_BRIDGE_DEST" 2>&1); then
        echo "$output"
        _error_handler "bridge.conf deployment"
    fi
    _log "success" "deployed bridge.conf"
fi

# Allow mDNS in nm-shared zone (for br-qemu bridge mDNS resolution)
if ! sudo firewall-cmd --zone=nm-shared --list-services 2>/dev/null | grep -qw mdns; then
    _log "info" "adding mdns service to nm-shared firewalld zone..."
    sudo firewall-cmd --zone=nm-shared --add-service=mdns --permanent
    sudo firewall-cmd --zone=nm-shared --add-port=8090/tcp --permanent
    sudo firewall-cmd --reload
    _log "success" "mdns service added to nm-shared zone"
else
    _log "info" "mdns service already in nm-shared zone, skipping"
fi
{{- end }}
