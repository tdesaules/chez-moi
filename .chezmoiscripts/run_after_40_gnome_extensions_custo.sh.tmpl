#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if and (eq .chezmoi.os "linux") (eq .desktop "GNOME") -}}

set -euo pipefail

error_handler() {
    _log "critical" "issue during gnome extension installation"
    exit 1
}
trap 'error_handler' ERR

_log "info" "configuring clipboard indicator..."
cat <<EOF | dconf load /org/gnome/shell/extensions/clipboard-indicator/
[/]
cache-images=true
cache-only-favorites=false
cache-size=5
case-sensitive-search=false
clear-history-on-interval=false
clear-on-boot=false
confirm-clear=false
disable-down-arrow=false
display-mode=0
enable-keybindings=false
history-size=50
keep-selected-on-clear=false
move-item-first=false
next-history-clear=-1
notify-on-copy=false
notify-on-cycle=false
paste-button=true
paste-on-select=false
pinned-on-bottom=false
regex-search=true
strip-text=true
topbar-preview-size=10
EOF
_log "success" "clipboard indicator configured"

# dconf dump /org/gnome/shell/extensions/tilingshell/
_log "info" "configuring tiling shell..."
cat <<EOF | dconf load /org/gnome/shell/extensions/tilingshell/
[/]
active-screen-edges=true
edge-tiling-mode='adaptive'
edge-tiling-offset=uint32 1
enable-autotiling=true
enable-blur-selected-tilepreview=false
enable-directional-focus-tiled-only=true
enable-screen-edges-windows-suggestions=true
enable-smart-window-border-radius=false
enable-snap-assist=true
enable-snap-assistant-windows-suggestions=true
enable-span-multiple-tiles=true
enable-tiling-system=true
enable-tiling-system-windows-suggestions=true
enable-window-border=true
inner-gaps=uint32 15
last-version-name-installed='17.3'
layouts-json='[{"id":"12645543","tiles":[{"x":0,"y":0,"width":1,"height":1,"groups":[]}]},{"id":"14770178","tiles":[{"x":0,"y":0,"width":0.5,"height":1,"groups":[1]},{"x":0.5,"y":0,"width":0.5000000000000011,"height":1,"groups":[1]}]},{"id":"14823575","tiles":[{"x":0,"y":0,"width":0.5,"height":1,"groups":[1]},{"x":0.5,"y":0,"width":0.5000000000000002,"height":0.5,"groups":[2,1]},{"x":0.5,"y":0.5,"width":0.5000000000000002,"height":0.5,"groups":[2,1]}]},{"id":"14865404","tiles":[{"x":0,"y":0,"width":0.33697916666666666,"height":1,"groups":[1]},{"x":0.33697916666666666,"y":0,"width":0.6630208333333334,"height":1,"groups":[1]}]},{"id":"15015851","tiles":[{"x":0,"y":0,"width":0.6630208333333333,"height":1,"groups":[1]},{"x":0.6630208333333333,"y":0,"width":0.33697916666666683,"height":1,"groups":[1]}]},{"id":"15055033","tiles":[{"x":0,"y":0,"width":0.6630208333333333,"height":1,"groups":[1]},{"x":0.6630208333333333,"y":0,"width":0.33697916666666655,"height":0.5034246575342466,"groups":[2,1]},{"x":0.6630208333333333,"y":0.5034246575342466,"width":0.33697916666666655,"height":0.4965753424657534,"groups":[2,1]}]}]'
outer-gaps=uint32 15
overridden-settings="{\"org.gnome.mutter.keybindings\":{\"toggle-tiled-right\":\"['<Super>Right']\",\"toggle-tiled-left\":\"['<Super>Left']\"},\"org.gnome.desktop.wm.keybindings\":{\"maximize\":\"['<Super>Up']\",\"unmaximize\":\"['<Super>Down', '<Alt>F5']\"},\"org.gnome.mutter\":{\"edge-tiling\":\"true\"}}"
override-window-menu=true
raise-together=true
selected-layouts=[['12645543'], ['12645543'], ['12645543'], ['12645543']]
snap-assist-sync-layout=true
span-multiple-tiles-activation-key=['0']
span-window-all-tiles=['<Super>Return']
tiling-system-activation-key=['0']
tiling-system-deactivation-key=['-1']
