_log "info" "configuring just perfection..."
cat <<EOF | dconf load /org/gnome/shell/extensions/just-perfection/
[/]
accent-color-icon=false
accessibility-menu=false
activities-button=true
background-menu=true
calendar=false
clock-menu=true
controls-manager-spacing-size=0
dash=true
