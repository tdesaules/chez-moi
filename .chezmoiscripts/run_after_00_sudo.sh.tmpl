#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if ( .is_linux ) }}

set -euo pipefail

# --- SUDO PRIVILEGE MANAGEMENT ---
_log "title" "Sudo Privilege Management"
trap '_error_handler "Sudo keep-alive process"' ERR

_log "info" "Requesting sudo privileges for the current chezmoi session..."

# -v (validate) updates the user's cached credentials
if sudo -v; then
    _log "notice" "Sudo access granted. Starting background keep-alive."

    # Background loop: Update the sudo timestamp every 60 seconds
    # It checks if the parent process (chezmoi) is still running via kill -0
    (
        while kill -0 "${PPID}" 2>/dev/null; do
            sudo -n true
            sleep 60
        done
    ) &>/dev/null &

    _log "success" "Sudo keep-alive is active (PID: $!)"
else
    _log "critical" "Failed to obtain sudo privileges. Automation may fail."
    exit 1
fi

# Reset trap for the end of this specific script
trap - ERR

{{ end }}
