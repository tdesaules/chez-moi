#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if (and (eq .chezmoi.os "linux") (eq .desktop "GNOME")) -}}

# --- CHEZMOI ONCHANGE HOOKS ---
# Python Script: {{ include "dot_local/bin/executable_gnome_workspace_wallpaper.py.tmpl" | sha256sum }}
# Service File:  {{ include "dot_config/systemd/user/gnome-workspace-wallpaper.service.tmpl" | sha256sum }}

set -euo pipefail

# --- CONFIGURATION ---
readonly GEXT_BIN="$HOME/.local/bin/gext"
readonly SERVICE_NAME="gnome-workspace-wallpaper.service"

readonly EXTENSIONS=(
    "7065" # Tiling Shell
    "779"  # Clipboard Indicator
    "3193" # Blur my Shell
    "3843" # Just Perfection
    "4269" # Alphabetical App Grid
)

# --- SECTION 1: GNOME EXTENSIONS ---
_log "title" "gnome extensions management"

trap '_error_handler "extension manager (gext) setup"' ERR
if ! command -v gext &> /dev/null; then
    _log "notice" "installing 'gext' via pipx..."
    pipx install gnome-extensions-cli
fi

trap '_error_handler "gnome shell extensions configuration"' ERR
gsettings set org.gnome.shell disable-user-extensions false

_log "info" "syncing extensions..."
$GEXT_BIN update --install --yes "${EXTENSIONS[@]}"
$GEXT_BIN enable "${EXTENSIONS[@]}"
_log "success" "extensions setup complete"


# --- SECTION 2: WALLPAPER DAEMON ---
_log "title" "deploy workspace wallpaper daemon"

trap '_error_handler "wallpaper daemon systemd configuration"' ERR

_log "info" "reloading systemd user daemon..."
systemctl --user daemon-reload

_log "info" "restarting ${SERVICE_NAME} to apply changes..."
systemctl --user enable "${SERVICE_NAME}"
systemctl --user restart "${SERVICE_NAME}"

if systemctl --user is-active --quiet "${SERVICE_NAME}"; then
    _log "success" "daemon is active and handling wallpapers"
else
    _error_handler "wallpaper daemon health check (service not active)"
fi

# Reset trap
trap - ERR

{{- end }}
