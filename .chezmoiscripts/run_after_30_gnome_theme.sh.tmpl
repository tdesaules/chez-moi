#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if and (eq .chezmoi.os "linux") (eq .desktop "GNOME") -}}

set -euo pipefail

# --- Configuration ---
# On prend la version de data, sinon la toute dernière connue au 16 Février 2025
{{ $version := .themes.graphite | default "" -}}
VERSION="{{ $version }}"
THEMES_DIR="$HOME/.themes"
MARKER="$THEMES_DIR/.graphite_version_$VERSION"

_log "info" "Vérification du thème Graphite ($VERSION)..."

if [ ! -f "$MARKER" ]; then
    _log "info" "Téléchargement de la version $VERSION..."
    mkdir -p "$THEMES_DIR"

    # L'URL des tags chez vinceliuice utilise souvent la date sans le 'v'
    URL="https://github.com/vinceliuice/Graphite-gtk-theme/archive/refs/tags/${VERSION}.tar.gz"
    TEMP_DIR=$(mktemp -d)

    if curl -sSL "$URL" -o "$TEMP_DIR/graphite.tar.gz"; then
        tar -xf "$TEMP_DIR/graphite.tar.gz" -C "$TEMP_DIR"

        # On cherche le dossier extrait (le nom peut varier légèrement)
        cd "$TEMP_DIR"/Graphite-gtk-theme-*

        _log "info" "Lancement de l'installateur..."
        # --libadwaita est indispensable pour Bazzite
        ./install.sh --dest "$THEMES_DIR" --libadwaita --round 8px > /dev/null 2>&1

        # Gestion du marqueur
        rm -f "$THEMES_DIR/.graphite_version_*"
        touch "$MARKER"
        _log "success" "Graphite mis à jour en version $VERSION"
    else
        _log "error" "Impossible de récupérer la version $VERSION. Vérifie le tag sur GitHub."
        exit 1
    fi
    rm -rf "$TEMP_DIR"
else
    _log "notice" "Graphite est déjà à la dernière version configurée ($VERSION)"
fi

# --- Application ---
# (Le reste du script pour gsettings et dconf reste identique)
gsettings set org.gnome.desktop.interface gtk-theme "Graphite-Dark"
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
dconf write /org/gnome/shell/extensions/user-theme/name "'Graphite-Dark'" 2>/dev/null || true

# Patch GTK4
mkdir -p "$HOME/.config/gtk-4.0"
ln -sf "$THEMES_DIR/Graphite-Dark/gtk-4.0/assets" "$HOME/.config/gtk-4.0/assets"
ln -sf "$THEMES_DIR/Graphite-Dark/gtk-4.0/gtk.css" "$HOME/.config/gtk-4.0/gtk.css"
ln -sf "$THEMES_DIR/Graphite-Dark/gtk-4.0/gtk-dark.css" "$HOME/.config/gtk-4.0/gtk-dark.css"

{{- end }}
