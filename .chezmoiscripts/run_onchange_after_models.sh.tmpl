#!/bin/bash

# Source the functions from the template
source "{{ .chezmoi.sourceDir }}/.chezmoitemplates/functions.sh.tmpl"

# Hash of config.kcl.tmpl to trigger on modification
# {{ include "dot_config/models/config.kcl.tmpl" | sha256sum }}

_log "title" "Updating Hugging Face models for Lemonade"

# Execute the pull script
SCRIPT_PATH="{{ .chezmoi.homeDir }}/.local/bin/pull-hf-models"

if [ ! -f "$SCRIPT_PATH" ]; then
    _log "error" "Pull script not found: $SCRIPT_PATH"
    exit 1
fi

if [ ! -x "$SCRIPT_PATH" ]; then
    _log "warning" "Pull script is not executable, fixing..."
    chmod +x "$SCRIPT_PATH"
fi

_log "info" "Executing pull script..."
if "$SCRIPT_PATH"; then
    _log "success" "Models updated successfully."
else
    _log "error" "Failed to update models."
    exit 1
fi
