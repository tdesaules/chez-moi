#!/bin/bash

{{- if .is_fedora }}

{{ include ".chezmoitemplates/functions.tmpl" }}

# {{ include "dot_local/share/udisks2/mount_options.conf" | sha256sum }}

SRC="{{ .chezmoi.homeDir }}/{{ .udisks2.src }}"
DEST="{{ .udisks2.dest }}"

if [ ! -f "$SRC" ]; then
    _error_handler "udisks2 mount_options.conf source not found"
fi

if [ -f "$DEST" ] && diff -q "$SRC" "$DEST" >/dev/null 2>&1; then
    _log "info" "mount_options.conf already up to date, skipping"
    exit 0
fi

_log "info" "deploying udisks2 mount_options.conf to $DEST..."
if ! output=$(sudo cp "$SRC" "$DEST" 2>&1); then
    echo "$output"
    _error_handler "udisks2 mount_options.conf deployment"
fi
_log "success" "deployed mount_options.conf to $DEST"

{{- end }}
