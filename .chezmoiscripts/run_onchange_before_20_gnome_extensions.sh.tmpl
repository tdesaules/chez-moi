#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if (and (eq .chezmoi.os "linux") (eq (index .chezmoi.env "XDG_CURRENT_DESKTOP") "GNOME")) -}}

set -euo pipefail

error_handler() {
    _log "critical" "issue during gnome extension installation"
    exit 1
}
trap 'error_handler' ERR

if ! command -v gext &> /dev/null; then
    _log "notice" "installing \"gext\"..."
    pipx install gnome-extensions-cli
    _log "notice" "\"gext\" installed"
fi

CURRENT_STATUS=
if [ "$(gsettings get org.gnome.shell disable-user-extensions)" = "true" ]; then
    _log "notice" "enable gnome user extensions support..."
    gsettings set org.gnome.shell disable-user-extensions false
    _log "notice" "gnome user extensions support enabled"
fi

EXTENSIONS=(
    "gesture-improvements@gestures"
    "forge@josemrb.com"
    "clipboard-indicator@tudmotu.com"
    "dash-to-dock@micxgx.gmail.com"
    "blur-my-shell@aunetx"
    "just-perfection-desktop@just-perfection"
    "user-theme@gnome-shell-extensions.gcampax.github.com"
    "appindicatorsupport@rgcjonas.gmail.com"
    "alphabetical-app-grid@stuarthayhurst"
)

_log "info" "installing extensions..."
$HOME/.local/bin/gext install "${EXTENSIONS[@]}" --update --enable
_log "success" "extensions installed"

{{ else -}}

{{ end -}}
