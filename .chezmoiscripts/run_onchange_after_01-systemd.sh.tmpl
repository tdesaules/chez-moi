#!/bin/bash

{{- if .is_systemd }}

{{ include ".chezmoitemplates/functions.tmpl" }}

# {{ include "dot_config/systemd/user/x11-unix.service.tmpl" | sha256sum }}
# {{ include "dot_config/systemd/user/filen-sync.service.tmpl" | sha256sum }}
# {{ include "dot_config/systemd/user/gopass-age-agent.service.tmpl" | sha256sum }}
# {{ include "dot_config/containers/systemd/lemonade-server.container.tmpl" | sha256sum }}
# {{ include "dot_config/containers/systemd/open-webui.container.tmpl" | sha256sum }}
# {{ include "dot_config/containers/systemd/beszel.container.tmpl" | sha256sum }}
# {{ include "dot_config/containers/systemd/beszel-agent.container.tmpl" | sha256sum }}
# {{ include ".chezmoidata/beszel.yaml" | sha256sum }}
# {{ include "dot_config/systemd/user/opencode-web.service.tmpl" | sha256sum }}
# {{ include "dot_config/systemd/user/gopass-age-usb-handler.path.tmpl" | sha256sum }}
# {{ include "dot_config/systemd/user/gopass-age-usb-handler.service.tmpl" | sha256sum }}

USER_SYSTEMD_DIR="{{ .chezmoi.homeDir }}/{{ .systemd.user_dir }}"
USER_CONTAINERS_DIR="{{ .chezmoi.homeDir }}/{{ .systemd.containers_dir }}"

_log "info" "reloading systemd user daemon..."
if ! output=$(systemctl --user daemon-reload 2>&1); then
    echo "$output"
    _error_handler "systemd user daemon reload"
fi
_log "success" "systemd user daemon reloaded."

_log "info" "podman quadlet containers in $USER_CONTAINERS_DIR will be processed by systemd daemon-reload."

services=$(find "$USER_SYSTEMD_DIR" -maxdepth 1 \( -name '*.service' -o -name '*.socket' -o -name '*.path' \) -printf '%f\n' 2>/dev/null)

if [ -z "$services" ]; then
    _log "info" "no systemd user service/socket files found."
else
    for service in $services; do
        _log "info" "enabling and starting $service..."
        if ! output=$(systemctl --user enable --now "$service" 2>&1); then
            echo "$output"
            _log "error" "failed to enable/start $service"
        else
            _log "success" "enabled and started $service"
        fi
    done
fi

containers=$(find "$USER_CONTAINERS_DIR" -maxdepth 1 -name '*.container' -printf '%f\n' 2>/dev/null)
WANTS_DIR="$USER_SYSTEMD_DIR/default.target.wants"

for container in $containers; do
    if ! grep -q "^\[Install\]" "${USER_CONTAINERS_DIR}/${container}" 2>/dev/null; then
        continue
    fi
    service="${container%.container}.service"
    _log "info" "enabling and starting $service..."
    mkdir -p "$WANTS_DIR"
    ln -sf "/run/user/$(id -u)/systemd/generator/${service}" "${WANTS_DIR}/${service}"
    if ! output=$(systemctl --user restart "$service" 2>&1); then
        echo "$output"
        _log "error" "failed to start $service"
    else
        _log "success" "enabled and started $service"
    fi
done

_log "success" "all systemd user services and quadlet containers processed."

{{- end }}
