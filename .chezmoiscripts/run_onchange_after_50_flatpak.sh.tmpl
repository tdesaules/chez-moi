#!/bin/bash

{{ template "functions.sh.tmpl" . }}

{{ if and (eq .chezmoi.os "linux") .flatpak -}}

# Flatpak management hash dependencies:
# gtk.css.tmpl: {{ include "dot_config/gtk-4.0/gtk.css.tmpl" | sha256sum }}

set -euo pipefail

# --- CONFIGURATION (From .chezmoidata/flatpak.yaml) ---
readonly FLATPAKS_TO_REMOVE=({{ range .flatpak.to_remove }}{{ . | quote }} {{ end }})
readonly FLATPAKS_TO_INSTALL=({{ range .flatpak.to_install }}{{ . | quote }} {{ end }})

# --- SECTION 1: CLEANUP ---
_log "title" "Flatpak Cleanup Management"
trap '_error_handler "Flatpak cleanup failed"' ERR

_log "info" "Scanning for unwanted Flatpak applications..."
INSTALLED_FLATPAKS=$(flatpak list --columns=application 2>/dev/null || true)

for APP in "${FLATPAKS_TO_REMOVE[@]}"; do
    if echo "${INSTALLED_FLATPAKS:-}" | grep -qxw "${APP}"; then
        _log "warning" "Removing ${APP}..."
        # Try user uninstall first, then fallback to system if needed
        flatpak uninstall --delete-data -y --user "${APP}" 2>/dev/null || \
        sudo flatpak uninstall --delete-data -y "${APP}"
    fi
done

_log "info" "Removing unused dependencies..."
flatpak uninstall --unused -y --user 2>/dev/null || true
sudo flatpak uninstall --unused -y 2>/dev/null || true

_log "success" "Cleanup completed"

# --- SECTION 2: INSTALLATION ---
_log "title" "Flatpak Installation Management"
trap '_error_handler "Flatpak installation failed"' ERR

_log "info" "Ensuring Flathub remote is configured..."
flatpak remote-add --user --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

_log "info" "Synchronizing application list..."
for APP in "${FLATPAKS_TO_INSTALL[@]}"; do
    if ! echo "${INSTALLED_FLATPAKS:-}" | grep -qxw "${APP}"; then
        _log "notice" "Installing ${APP}..."
        flatpak install -y --user flathub "${APP}"
    else
        _log "notice" "${APP} is already installed"
    fi
done

_log "success" "Applications synchronized"

# --- SECTION 3: THEME & UPDATES ---
_log "title" "Flatpak Environment Optimization"
trap '_error_handler "Flatpak environment setup failed"' ERR

_log "info" "Granting Flatpak apps access to GTK custom themes..."
# This allows Flatpaks to read your Nord GTK theme files
flatpak override --user --filesystem=xdg-config/gtk-4.0:ro
flatpak override --user --filesystem=xdg-config/gtk-3.0:ro

_log "info" "Checking for updates..."
flatpak update -y --user
sudo flatpak update -y 2>/dev/null || true

_log "success" "Flatpak environment is up to date and themed"

# Final cleanup
trap - ERR

{{- end }}
