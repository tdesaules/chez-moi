{{- $is_linux := false -}}
{{- if ( eq .chezmoi.os "linux" ) -}}
    {{- $is_linux = true -}}
{{- end -}}

{{- $is_fedora := false -}}
{{- if ( eq .chezmoi.osRelease.id "fedora" ) -}}
    {{- $is_fedora = true -}}
{{- end -}}

{{- $atomic_version := "" -}}
{{- if $is_fedora -}}
    {{- $atomic_version = output "sh" "-c" "rpm-ostree status --json | jq -r '.deployments[] | select(.booted == true) | .[\"container-image-reference\"]' | awk -F: '{print $NF}'" | trim -}}
{{- end -}}

{{- $is_mise := false -}}
{{- if ( lookPath "mise" ) -}}
    {{- $is_mise = true -}}
{{- end -}}

{{- $is_nushell := false -}}
{{- if ( lookPath "nu" ) -}}
    {{- $is_nushell = true -}}
{{- end -}}

{{- $is_ssh := false -}}
{{- if ( lookPath "ssh-keygen" ) -}}
    {{- $is_ssh = true -}}
{{- end -}}

[data]
    is_linux = {{ $is_linux }}
    is_fedora = {{ $is_fedora }}
    is_mise = {{ $is_mise }}
    is_nushell = {{ $is_nushell }}
    is_ssh = {{ $is_ssh }}
    atomic_version = {{ $atomic_version }}
