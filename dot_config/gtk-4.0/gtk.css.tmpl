/* --- COULEURS D'ACCENTUATION (Aurora - nord11) --- */
@define-color accent_color #bf616a;
@define-color accent_bg_color #bf616a;
@define-color accent_fg_color #eceff4; /* Texte sur l'accent (nord6) */

/* --- FONDS ET FENÊTRES (Polar Night) --- */
/* Fond principal des fenêtres (nord0) */
@define-color window_bg_color #2e3440;
@define-color window_fg_color #d8dee9; /* Texte principal (nord4) */

/* Fond des zones de contenu comme les listes (nord0) */
@define-color view_bg_color #2e3440;
@define-color view_fg_color #d8dee9;

/* --- BARRES D'EN TÊTE (Headerbar) --- */
@define-color headerbar_bg_color #2e3440;
@define-color headerbar_fg_color #eceff4; /* Texte plus clair pour les titres (nord6) */
@define-color headerbar_border_color #434c5e; /* Ligne de séparation (nord2) */
@define-color headerbar_backdrop_color #2e3440;

/* --- BARRES LATÉRALES ET CARTES (Polar Night plus clair) --- */
/* Fonds des sidebars dans Nautilus ou Paramètres (nord1) */
@define-color sidebar_bg_color #3b4252;
@define-color sidebar_fg_color #d8dee9;
@define-color sidebar_backdrop_color #3b4252;

/* Fonds des "cartes" ou blocs dans les Paramètres (nord1) */
@define-color card_bg_color #3b4252;
@define-color card_fg_color #d8dee9;

/* Menus déroulants et pop-ups (nord1) */
@define-color popover_bg_color #3b4252;
@define-color popover_fg_color #eceff4;

/* --- INTERACTIONS ET SÉLECTIONS --- */
/* Survol (Hover) avec un fond très léger de l'accent (Aurora avec transparence) */
@define-color fill_color rgba(191, 97, 106, 0.1);
/* Éléments sélectionnés sans le focus direct */
@define-color selection_bg_color rgba(191, 97, 106, 0.25);

/* --- MESSAGES D'ÉTAT (Aurora) --- */
/* Succès (nord14 - Green) */
@define-color success_color #a3be8c;
@define-color success_bg_color #a3be8c;
@define-color success_fg_color #2e3440;

/* Avertissement (nord13 - Yellow) */
@define-color warning_color #ebcb8b;
@define-color warning_bg_color #ebcb8b;
@define-color warning_fg_color #2e3440;

/* Erreur / Destructeur (nord11 - Red) - Se confond avec l'accent ici, ce qui est cohérent */
@define-color destructive_color #bf616a;
@define-color destructive_bg_color #bf616a;
@define-color destructive_fg_color #eceff4;
@define-color error_color #bf616a;
@define-color error_bg_color #bf616a;
@define-color error_fg_color #eceff4;

/* --- BORDURES ET SÉPARATEURS (Frost & Polar Night) --- */
/* Bordures générales (nord3) */
@define-color border_color #4c566a;
/* Lignes de séparation très subtiles */
@define-color separator_color rgba(76, 86, 106, 0.5);
