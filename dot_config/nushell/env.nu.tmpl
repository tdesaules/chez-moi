# env.nu

let cache_dir = "{{ .chezmoi.homeDir }}/.cache/nushell"
if not ($cache_dir | path exists) { mkdir $cache_dir }

if (not (help commands | where name == "starship" | is-empty)) {
    starship init nu | save --force ($cache_dir | path join "starship.nu")
}

if (not (help commands | where name == "mise" | is-empty)) {
    mise activate nu | save --force ($cache_dir | path join "mise.nu")
}
