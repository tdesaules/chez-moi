[Unit]
Description=Open Terminal
After=network.target open-webui.service
BindsTo=open-webui.service

[Container]
Image=ghcr.io/open-webui/open-terminal:latest
ContainerName=open-terminal
Network=ai.network
PublishPort=127.0.0.1:8000:8000
Volume=open-terminal:/home/user
Environment=OPEN_TERMINAL_API_KEY=empty
Environment=OPEN_TERMINAL_EXECUTE_TIMEOUT=5
