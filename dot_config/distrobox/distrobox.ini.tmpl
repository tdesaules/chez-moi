[chromium-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="chromium-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="dnf --assumeyes --quiet upgrade && dnf --assumeyes --quiet autoremove"
additional_packages="chromium"
init_hooks="update-ca-trust"

[zen-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="zen-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="dnf copr enable --assumeyes myriad-sun/zen-browser"
pre_init_hooks="dnf --assumeyes --quiet upgrade && dnf --assumeyes --quiet autoremove"
additional_packages="zen-browser"
init_hooks="update-ca-trust"
exported_apps="{{ .chezmoi.homeDir }}/.config/distrobox/zen.perso.desktop {{ .chezmoi.homeDir }}/.config/distrobox/zen.devoteam.desktop"

[browseros-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="zen-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="dnf copr enable --assumeyes metal3d/BrowserOS"
pre_init_hooks="dnf --assumeyes --quiet upgrade && dnf --assumeyes --quiet autoremove"
additional_packages="browserosr"
init_hooks="update-ca-trust"

[zed-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="zed-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="if [[ ! -f /etc/yum.repos.d/terra.repo ]]; then dnf install --nogpgcheck --assumeyes --repofrompath 'terra,https://repos.fyralabs.com/terrarawhide' terra-release; fi"
pre_init_hooks="dnf --assumeyes --quiet upgrade && dnf --assumeyes --quiet autoremove"
additional_packages="zed"
init_hooks="update-ca-trust"
exported_bins="/usr/bin/zed"
exported_bins_path="{{ .chezmoi.homeDir }}/.local/bin"
exported_apps="/usr/share/applications/dev.zed.Zed.desktop"

[steam-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="steam-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="if [[ ! -f /etc/yum.repos.d/terra.repo ]]; then dnf install --nogpgcheck --assumeyes --repofrompath 'terra,https://repos.fyralabs.com/terrarawhide' terra-release; fi"
pre_init_hooks="dnf --assumeyes --quiet upgrade && dnf --assumeyes --quiet autoremove"
additional_packages="glx-utils vulkan-tools lsb_release pciutils pipewire-libs gamemode mangohud lutris steam"
init_hooks="update-ca-trust"
