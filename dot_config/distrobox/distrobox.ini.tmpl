[zed-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="zed-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
pre_init_hooks="if [[ ! -f /etc/yum.repos.d/terra.repo ]]; then dnf install --nogpgcheck --assumeyes --repofrompath 'terra,https://repos.fyralabs.com/terrarawhide' terra-release; fi"
additional_packages="zed"
exported_bins="/usr/bin/zed"
exported_bins_path="{{ .chezmoi.homeDir }}/.local/bin"
exported_apps="/usr/share/applications/dev.zed.Zed.desktop"

[zen-distrobox]
image=docker.io/fedora:rawhide
replace=true
start_now=true
entry=false
hostname="zen-distrobox"
pre_init_hooks="export SHELL='/bin/bash'"
init_hooks="mkdir -p {{ .chezmoi.homeDir }}/Applications"
pre_init_hooks='if [[ ! -f "{{ .chezmoi.homeDir }}/Applications/zen-{{ .distrobox.zen.version }}-x86_64.AppImage" ]]; then curl -sSL -o "{{ .chezmoi.homeDir }}/Applications/zen-{{ .distrobox.zen.version }}-x86_64.AppImage" "https://github.com/zen-browser/desktop/releases/download/{{ .distrobox.zen.version }}/zen-x86_64.AppImage"; fi'
pre_init_hooks="chmod +x {{ .chezmoi.homeDir }}/Applications/zen-{{ .distrobox.zen.version }}-x86_64.AppImage"
