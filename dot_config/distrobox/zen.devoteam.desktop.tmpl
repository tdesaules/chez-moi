[Desktop Entry]
Version=1.0
Name=Zen Devoteam
Exec=zen-browser --profile "{{ .chezmoi.homeDir }}/.zen/devoteam" --name zen-devoteam %u
Icon={{ .chezmoi.homeDir }}/.local/share/icons/zen-devoteam.svg
Type=Application
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;application/x-xpinstall;application/pdf;application/json;
StartupWMClass=zen-devoteam
Categories=Network;WebBrowser;
StartupNotify=true
Terminal=false
X-MultipleArgs=false
Keywords=Internet;WWW;Browser;Web;Explorer;
Actions=new-window;new-blank-window;new-private-window;profilemanager;
X-Flatpak=app.zen_browser.zen

[Desktop Action new-window]
Name=Open a New Window (Devoteam)
Exec=zen-browser --profile "{{ .chezmoi.homeDir }}/.zen/devoteam" --name zen-devoteam --new-window %u

[Desktop Action new-blank-window]
Name=Open a New Blank Window (Devoteam)
Exec=zen-browser --profile "{{ .chezmoi.homeDir }}/.zen/devoteam" --name zen-devoteam --blank-window %u

[Desktop Action new-private-window]
Name=Open a New Private Window (Devoteam)
Exec=zen-browser --profile "{{ .chezmoi.homeDir }}/.zen/devoteam" --name zen-devoteam --private-window %u

[Desktop Action profilemanager]
Name=Open the Profile Manager
Exec=zen-browser --ProfileManager
