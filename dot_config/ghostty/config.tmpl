# --- Font Settings ---
font-family = "Geist Mono"
font-size = 10.5

# Documentation: adjust-cell-height increases line spacing
# 15% is equivalent to a 1.15 line-height
adjust-cell-height = 15%

# --- Graphite-Nordic Theme ---
background = #1e1e1e
foreground = #d8dee9
selection-background = #3b4252
selection-foreground = #eceff4

# Nordic Palette
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# --- Cursor & Selection ---
cursor-color = #88c0d0
cursor-style = block
# Documentation: cursor-style-blink controls blinking
cursor-style-blink = false
copy-on-select = true

# --- Window Appearance ---
window-decoration = false
window-padding-x = 12
window-padding-y = 12

# Documentation: background-opacity and background-blur (no 'window-' prefix)
background-opacity = 0.92
background-blur = true

split-divider-color = #4c566a

# --- Cross-Platform Adaptation (Mac vs Linux) ---
{{ if (eq .chezmoi.os "darwin") -}}
font-size = 13
font-thicken = true
{{ end -}}
