font-family = "Geist Mono"
font-size = 10.5
adjust-line-height = 115%
font-feature = -calt, -liga, -dlig

background = #1e1e1e
foreground = #d8dee9
selection-background = #3b4252
selection-foreground = #eceff4

palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

cursor-color = #88c0d0
cursor-style = block
cursor-blink = false

window-decoration = false
window-padding-x = 12
window-padding-y = 12
window-background-opacity = 0.95
window-background-blur = true
split-divider-color = #4c566a

minimum-contrast = 1.1

copy-on-select = true

window-theme = dark
