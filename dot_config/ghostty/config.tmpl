# --- Font Settings ---
font-family = "Geist Mono"
font-size = 10.5
# Use 'line-height' for newer Ghostty versions (replaces adjust-line-height)
line-height = 1.15

# --- Graphite-Nordic Theme ---
background = #1e1e1e
foreground = #d8dee9
selection-background = #3b4252
selection-foreground = #eceff4

# Nordic Palette (Matches Bazzite/GNOME aesthetic)
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# --- Cursor & Selection ---
cursor-color = #88c0d0
cursor-style = block
# 'copy-on-select' for a native Linux feel
copy-on-select = true

# --- Window Appearance (Minimalist Graphite Style) ---
window-decoration = false
window-padding-x = 12
window-padding-y = 12

# Transparency & Blur (Modern GTK look)
background-opacity = 0.95
background-blur = true

# Layout
split-divider-color = #4c566a

# --- Cross-Platform Adaptation (Mac vs Linux) ---
{{ if (eq .chezmoi.os "darwin") -}}
font-size = 13
# Enable font thickening specifically for Retina displays
font-thicken = true
{{ end -}}
