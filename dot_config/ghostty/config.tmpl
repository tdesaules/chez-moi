# --- Shell ---
# command = {{ .chezmoi.homeDir }}/.local/share/mise/shims/nu

# --- Font Settings ---
# Primary font
font-family = "Geist Pixel Square"
font-family = "Symbols Nerd Font Mono"
font-size = 10

# Adjust-cell-height increases line spacing
# 15% is equivalent to a 1.15 line-height and width
adjust-cell-width = -25%

# --- Nord Palette (Polar Night & Aurora Red) ---
# Main background (Nord0)
background = #2e3440
# Main foreground text (Nord4)
foreground = #d8dee9

# Selection colors (Nord2 for background to keep a dark accent)
selection-background = #434c5e
selection-foreground = #eceff4

# Standard Nord palette mapping
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# --- Cursor & Selection ---
# Aurora Red accent for the cursor
cursor-color = #bf616a
# Text color underneath the cursor
cursor-text = #eceff4

cursor-style = block
cursor-style-blink = false
copy-on-select = true

# --- Window Appearance ---
# Set to true to allow GNOME/GTK4 to apply native rounded corners
window-decoration = true

# Force dark mode for the GTK4 window wrapper
window-theme = dark

window-padding-x = 12
window-padding-y = 12
# Extend the background color into the padding area seamlessly
window-padding-color = extend

# Opacity must be lower than 1 for the blur effect to be visible
background-opacity = 0.9
background-blur = true

split-divider-color = #4c566a

{{ if (eq .chezmoi.os "darwin") -}}
font-size = 13
font-thicken = true
# Hide the titlebar on macOS while keeping native rounded corners
window-decoration = false
macos-titlebar-style = hidden

{{ end -}}
