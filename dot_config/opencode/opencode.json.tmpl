    "zai-coding-plan",
    "umans",
    "lemonade"
  ],
  "provider": {
    "lemonade": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Lemonade",
      "options": {
        "baseURL": "http://127.0.0.1:13305/v1",
        "apiKey": "empty"
      },
      "models": {
        "user.Devstral-Small-2-24B-Instruct-2512-Q8_0": {
          "name": "Devstral-Small-2-24B"
        }
      }
    },
    "umans": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Umans AI",
      "options": {
        "baseURL": "https://api.code.umans.ai/v1",
        "apiKey": "{{ gopass \"perso/token/umans.ai/e7564783-7052-48cf-acdf-15b53811a6e2\" | trim }}"
      },
      "models": {
        "umans-kimi-k2.7": {
          "id": "umans-kimi-k2.7",
